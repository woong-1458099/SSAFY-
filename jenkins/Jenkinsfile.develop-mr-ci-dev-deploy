pipeline {
  agent any

  parameters {
    choice(name: 'TARGET_COLOR', choices: ['green', 'blue'], description: 'Deploy target color')
    string(name: 'EC2_HOST', defaultValue: '', description: 'EC2 public host or IP')
    string(name: 'REMOTE_PROJECT_DIR', defaultValue: '~/apps/S14P21E206', description: 'Remote project directory')
    booleanParam(name: 'AUTO_SWITCH', defaultValue: true, description: 'Switch nginx upstream after deploy')
  }

  environment {
    COMPOSE_ARGS = '-p stg-app --env-file docker/.env.stg -f docker/compose.app.yml'
  }

  stages {
    stage('Validate Params') {
      steps {
        script {
          if (!params.EC2_HOST?.trim()) {
            error('EC2_HOST is required')
          }
        }
      }
    }

    stage('Deploy Target Color') {
      steps {
        sshagent(credentials: ['ec2-deploy-ssh']) {
          sh '''
            set -eu
            ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} "
              cd ${REMOTE_PROJECT_DIR} &&
              docker compose ${COMPOSE_ARGS} up -d api-${TARGET_COLOR}
            "
          '''
        }
      }
    }

    stage('Health Check') {
      steps {
        sshagent(credentials: ['ec2-deploy-ssh']) {
          sh '''
            set -eu
            ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} "
              cd ${REMOTE_PROJECT_DIR} &&
              docker compose ${COMPOSE_ARGS} ps api-${TARGET_COLOR} &&
              sleep 2 &&
              docker exec stg-app-api-${TARGET_COLOR}-1 curl -fsS http://localhost:8080/actuator/health
            "
          '''
        }
      }
    }

    stage('Switch Nginx Upstream') {
      when {
        expression { return params.AUTO_SWITCH }
      }
      steps {
        sshagent(credentials: ['ec2-deploy-ssh']) {
          sh '''
            set -eu
            ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} "
              cd ${REMOTE_PROJECT_DIR} &&
              printf 'upstream api_upstream {\\n  server api-${TARGET_COLOR}:8080;\\n}\\n' > Infra/infra/nginx/upstreams/active.conf &&
              docker exec stg-app-nginx-1 nginx -s reload
            "
          '''
        }
      }
    }

    stage('Verify And Rollback') {
      when {
        expression { return params.AUTO_SWITCH }
      }
      steps {
        sshagent(credentials: ['ec2-deploy-ssh']) {
          sh '''
            set -eu
            rollback_color=blue
            if [ "${TARGET_COLOR}" = "blue" ]; then
              rollback_color=green
            fi

            ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} "
              set -eu
              cd ${REMOTE_PROJECT_DIR}
              response=\\$(curl -fsS --max-time 5 http://localhost/api/public/checks || true)
              if echo \\\"\\$response\\\" | grep -q '\"db\":\"UP\"' && echo \\\"\\$response\\\" | grep -q '\"redis\":\"UP\"'; then
                echo 'verify success'
              else
                echo 'verify failed. rollback to '${rollback_color}
                printf 'upstream api_upstream {\\\\n  server api-${rollback_color}:8080;\\\\n}\\\\n' > Infra/infra/nginx/upstreams/active.conf
                docker exec stg-app-nginx-1 nginx -s reload
                exit 1
              fi
            "
          '''
        }
      }
    }
  }

  post {
    success {
      echo "Deploy success: ${params.TARGET_COLOR}"
    }
    failure {
      script {
        def rollbackColor = params.TARGET_COLOR == 'green' ? 'blue' : 'green'
        echo "Deploy failed. Suggested rollback color: ${rollbackColor}"
      }
    }
  }
}
