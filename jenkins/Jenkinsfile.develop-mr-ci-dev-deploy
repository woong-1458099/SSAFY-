pipeline {
  agent any

  options {
    timestamps()
    disableConcurrentBuilds()
  }

  parameters {
    booleanParam(
      name: 'SKIP_PATH_FILTER',
      defaultValue: false,
      description: 'true면 경로 변경 감지(Diff) 없이 백엔드 파이프라인을 강제 실행합니다. (수동 테스트용)'
    )
    booleanParam(
      name: 'AUTO_SWITCH',
      defaultValue: true,
      description: 'Switch nginx upstream after deploy'
    )
  }

  environment {
    EC2_HOST = '13.125.26.13'
    REMOTE_PROJECT_DIR = '/home/ubuntu/apps/S14P21E206'
    COMPOSE_ARGS = '-p stg-app --env-file docker/.env.stg -f docker/compose.app.yml'
    JAVA_HOME = '/opt/java/openjdk'
    PATH = "/opt/java/openjdk/bin:${env.PATH}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Detect Changes') {
      steps {
        script {
          if (params.SKIP_PATH_FILTER) {
            echo 'SKIP_PATH_FILTER=true -> backend path filter skipped'
            return
          }

          def changed = []
          for (changeLog in currentBuild.changeSets) {
            for (entry in changeLog.items) {
              for (file in entry.affectedFiles) {
                changed << file.path
              }
            }
          }

          changed = changed.unique()

          def backendChanged = changed.any { it ==~ /^BackEnd\/.+/ }

          echo "backendChanged=${backendChanged}"
          echo "changedFilesCount=${changed.size()}"
          if (changed) {
            echo "changedFiles=${changed.join(', ')}"
          } else {
            echo 'No changelog entries found from Jenkins changeSets.'
          }

          if (!backendChanged) {
            currentBuild.description = 'Skip: BackEnd changes not found'
            currentBuild.result = 'NOT_BUILT'
            error('No BackEnd changes. Stop backend pipeline.')
          }
        }
      }
    }

    stage('Resolve Image Tag (Commit SHA)') {
      steps {
        script {
          env.IMAGE_TAG = sh(returnStdout: true, script: 'git rev-parse --short=12 HEAD').trim()
          env.BACKEND_IMAGE = "s14p21e206-backend:${env.IMAGE_TAG}"
          echo "BACKEND_IMAGE=${env.BACKEND_IMAGE}"
        }
      }
    }

    stage('Test') {
      steps {
          sh '''
            set -eu
            chmod +x BackEnd/gradlew
            ./BackEnd/gradlew test --no-daemon -p BackEnd
          '''
      }
    }

    stage('Build Jar') {
      steps {
        sh '''
          set -eu
          chmod +x BackEnd/gradlew
          ./BackEnd/gradlew bootJar --no-daemon -p BackEnd
        '''
      }
    }

    stage('Build Docker Image On EC2') {
      steps {
        sshagent(credentials: ['ec2-deploy-ssh-v2']) {
          sh """
            set -eu
            ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} "
              cd ${REMOTE_PROJECT_DIR} &&
              docker build -t ${env.BACKEND_IMAGE} BackEnd
            "
          """
        }
      }
    }

    stage('Detect Active Color') {
      steps {
        sshagent(credentials: ['ec2-deploy-ssh-v2']) {
          script {
            def activeColor = sh(
              returnStdout: true,
              script: """
                set -eu
                ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} "
                  cd ${REMOTE_PROJECT_DIR} &&
                  if grep -q 'api-green:8080' /home/ubuntu/deploy/nginx/upstreams/active.conf; then
                    echo green
                  elif grep -q 'api-blue:8080' /home/ubuntu/deploy/nginx/upstreams/active.conf; then
                    echo blue
                  else
                    echo unknown
                  fi
                "
              """
            ).trim()

            if (activeColor == 'unknown') {
              error('Cannot detect active color from active.conf')
            }

            env.ACTIVE_COLOR = activeColor
            env.TARGET_COLOR = (activeColor == 'green') ? 'blue' : 'green'
            echo "ACTIVE_COLOR=${env.ACTIVE_COLOR}, TARGET_COLOR=${env.TARGET_COLOR}"
          }
        }
      }
    }

    stage('Deploy Target Color') {
      steps {
        sshagent(credentials: ['ec2-deploy-ssh-v2']) {
          sh """
            set -eu
            ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} "
              cd ${REMOTE_PROJECT_DIR} &&
              BACKEND_IMAGE=${env.BACKEND_IMAGE} docker compose ${COMPOSE_ARGS} up -d api-${env.TARGET_COLOR}
            "
          """
        }
      }
    }

    stage('Health Check') {
      steps {
        sshagent(credentials: ['ec2-deploy-ssh-v2']) {
          withEnv([
            "EC2_HOST=${env.EC2_HOST}",
            "REMOTE_PROJECT_DIR=${env.REMOTE_PROJECT_DIR}",
            "TARGET_COLOR=${env.TARGET_COLOR}"
          ]) {
            sh '''
set -eu
ssh -o StrictHostKeyChecking=no ubuntu@$EC2_HOST "TARGET_COLOR='$TARGET_COLOR' REMOTE_PROJECT_DIR='$REMOTE_PROJECT_DIR' bash -se" <<'EOSSH'
set -eu
cd $REMOTE_PROJECT_DIR

docker compose -p stg-app --env-file docker/.env.stg -f docker/compose.app.yml ps api-$TARGET_COLOR

for i in $(seq 1 20); do
  body=$(docker exec stg-app-nginx-1 sh -c "wget -qO- http://api-$TARGET_COLOR:8080/actuator/health" || true)
  echo "health[$i]=$body"
  echo "$body" | grep -Eq '"status"[[:space:]]*:[[:space:]]*"UP"' && exit 0
  sleep 3
done

echo "health check failed"
docker logs stg-app-api-$TARGET_COLOR-1 --tail 120 || true
exit 1
EOSSH
            '''
          }
        }
      }
    }

    stage('Switch Nginx Upstream') {
      when {
        expression { return params.AUTO_SWITCH }
      }
      steps {
        sshagent(credentials: ['ec2-deploy-ssh-v2']) {
          sh """
            set -eu
            ssh -o StrictHostKeyChecking=no ubuntu@${EC2_HOST} "
              cd ${REMOTE_PROJECT_DIR} &&
              printf 'upstream api_upstream {\\n  server api-${env.TARGET_COLOR}:8080;\\n}\\n' > /home/ubuntu/deploy/nginx/upstreams/active.conf &&
              docker exec stg-app-nginx-1 nginx -s reload
            "
          """
        }
      }
    }

    stage('Verify And Rollback') {
      when {
        expression { return params.AUTO_SWITCH }
      }
      steps {
        sshagent(credentials: ['ec2-deploy-ssh-v2']) {
          withEnv([
            "EC2_HOST=${env.EC2_HOST}",
            "REMOTE_PROJECT_DIR=${env.REMOTE_PROJECT_DIR}",
            "TARGET_COLOR=${env.TARGET_COLOR}"
          ]) {
            sh '''
              set -eu
              rollback_color=blue
              if [ "$TARGET_COLOR" = "blue" ]; then
                rollback_color=green
              fi

              ssh -o StrictHostKeyChecking=no ubuntu@$EC2_HOST "
                set -eu
                cd $REMOTE_PROJECT_DIR
                response=\\$(docker exec stg-app-nginx-1 sh -c 'wget -qO- http://api-$TARGET_COLOR:8080/actuator/health' || true)

                if echo \\"\\$response\\" | grep -q '\\"status\\":\\"UP\\"'; then
                  echo verify success
                else
                  echo verify failed. rollback to \\$rollback_color
                  printf 'upstream api_upstream {\\\\n  server api-%s:8080;\\\\n}\\\\n' \\$rollback_color > /home/ubuntu/deploy/nginx/upstreams/active.conf
                  docker exec stg-app-nginx-1 nginx -s reload
                  exit 1
                fi
              "
            '''
          }
        }
      }
    }
  }
  post {
    success {
      echo "Deploy success: ${env.TARGET_COLOR}, image=${env.BACKEND_IMAGE}"
    }
    failure {
      script {
        def rollbackColor = env.ACTIVE_COLOR ?: 'unknown'
        echo "Deploy failed. Rollback target(keep current active): ${rollbackColor}"
      }
    }
  }
}