    {
      "parameters": {
        "jsCode": "const changes = $json.changes || [];\n\nconst totalDiffLength = changes.reduce((sum, change) => {\n  return sum + ((change.diff || '').length);\n}, 0);\n\nconst fileCount = changes.length;\n\nconst changedFiles = changes.map(change =>\n  `${change.new_path || ''} ${change.old_path || ''}`.toLowerCase()\n);\n\nconst highRiskKeywords = [\n  'auth',\n  'security',\n  'jwt',\n  'token',\n  'keycloak',\n  'oauth',\n  'login',\n  'signup',\n  'password',\n  'session',\n  'cookie',\n  'permission',\n  'role',\n  'admin'\n];\n\nconst hasHighRiskFile = changedFiles.some(file =>\n  highRiskKeywords.some(keyword => file.includes(keyword))\n);\n\nconst hasLargeDiff = totalDiffLength > 12000 || fileCount >= 8;\n\nconst selected_model =\n  hasHighRiskFile || hasLargeDiff\n    ? 'gpt-5.3-codex'\n    : 'gpt-5.1-codex-mini';\n\nreturn {\n  json: {\n    ...$json,\n    total_diff_length: totalDiffLength,\n    changed_file_count: fileCount,\n    has_high_risk_file: hasHighRiskFile,\n    has_large_diff: hasLargeDiff,\n    selected_model\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -880,
        272
      ],
      "id": "8fe0dfc5-a095-4301-b68c-2d8a596c8ed5",
      "name": "Choose Model"
    },
    {
      "parameters": {
        "jsCode": "const rawAuthor = $json.author;\nconst author =\n  typeof rawAuthor === 'string'\n    ? rawAuthor\n    : rawAuthor?.username || rawAuthor?.name || 'unknown';\n\nconst selectedModel =\n  $json.selected_model ||\n  $('Choose Model').first().json.selected_model ||\n  'unknown';\n\nreturn {\n  json: {\n    status: 'success',\n    mr_iid: $json.mr_iid,\n    mr_title: $json.mr_title || '',\n    author,\n    source_branch: $json.source_branch || '',\n    target_branch: $json.target_branch || '',\n    mr_type: $json.mr_type || 'chore',\n    overall_risk: $json.overall_risk || 'medium',\n    summary: $json.summary || '',\n    findings: Array.isArray($json.findings) ? $json.findings : [],\n    findings_count: $json.findings_count || 0,\n    comment_markdown: $json.comment_markdown || '',\n    commit_sha: $json.commit_sha || '',\n    selected_model: selectedModel,\n    gitlab_mr_url: $json.gitlab_mr_url || '',\n    timestamp: $json.timestamp || new Date().toISOString(),\n    error_message: ''\n  }\n};"
      },
