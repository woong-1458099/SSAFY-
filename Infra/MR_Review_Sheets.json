    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const raw = $input.item.json;\nconst fallback = {\n  mr_type: 'chore',\n  summary: '리뷰 생성은 완료되었지만 파서 fallback이 사용되었습니다.',\n  overall_risk: 'medium',\n  findings: [],\n  comment_markdown: '자동 리뷰는 완료되었지만 응답 파싱이 완전하지 않았습니다. 원본 출력은 실행 로그를 확인해주세요.'\n};\n\nlet text = '';\nif (raw.output_text) text = raw.output_text;\nelse if (Array.isArray(raw.output)) {\n  const chunks = [];\n  for (const o of raw.output) {\n    if (Array.isArray(o.content)) {\n      for (const c of o.content) {\n        if (c.type === 'output_text' && c.text) chunks.push(c.text);\n      }\n    }\n  }\n  text = chunks.join('\\n');\n}\n\nlet parsed = fallback;\ntry {\n  parsed = JSON.parse(text);\n} catch (e) {\n  parsed = {\n    ...fallback,\n    comment_markdown: `자동 리뷰 원문 출력:\\n\\n\\`\\`\\`\\n${text.slice(0, 3500)}\\n\\`\\`\\``\n  };\n}\n\nreturn {\n  json: {\n    ...$json,\n    mr_type: parsed.mr_type || 'chore',\n    summary: parsed.summary || fallback.summary,\n    overall_risk: parsed.overall_risk || 'medium',\n    findings: Array.isArray(parsed.findings) ? parsed.findings : [],\n    findings_count: Array.isArray(parsed.findings) ? parsed.findings.length : 0,\n    comment_markdown: parsed.comment_markdown || fallback.comment_markdown\n  }\n};"
      },
