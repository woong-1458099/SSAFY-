TZ=Asia/Seoul
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/
N8N_ENCRYPTION_KEY=change-this-to-a-long-random-string
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-password

# Jenkins local test target
JENKINS_BASE_URL=http://host.docker.internal:8080
JENKINS_JOB_NAME=backend-ci
JENKINS_USER=kimminsu
JENKINS_API_TOKEN=replace-with-user-api-token
JENKINS_REMOTE_TOKEN=replace-with-job-remote-token

# GitLab MR review automation
GITLAB_BASE_URL=https://lab.ssafy.com
GITLAB_PROJECT_ID=replace-project-id
GITLAB_TOKEN=replace-gitlab-api-token

# OpenAI/Codex review
OPENAI_API_KEY=replace-openai-api-key
OPENAI_MODEL=gpt-4.1-mini

# Google Sheets ingestion endpoint (Apps Script Web App or internal API)
SHEETS_WEBHOOK_URL=https://example.com/sheets-ingest
