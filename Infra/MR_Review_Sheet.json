        "jsCode": "const summary = $json.summary || '요약 정보가 없습니다.';\nconst overallRisk = $json.overall_risk || 'medium';\nconst findings = Array.isArray($json.findings) ? $json.findings : [];\n\nconst riskLabelMap = {\n  low: 'low',\n  medium: 'medium',\n  high: 'high'\n};\n\nconst lines = [\n  '## 요약',\n  summary,\n  '',\n  '## 위험도',\n  riskLabelMap[overallRisk] || overallRisk,\n  '',\n  '## 주요 이슈'\n];\n\nif (findings.length === 0) {\n  lines.push('- 중요한 이슈 없음');\n} else {\n  for (const finding of findings) {\n    const severity = finding?.severity || 'unknown';\n    const file = finding?.file || 'unknown-file';\n    const lineHint = finding?.line_hint || 'line unknown';\n    const issue = finding?.issue || '문제 설명 없음';\n    const suggestion = finding?.suggestion || '개선 제안 없음';\n\n    lines.push(`- [${severity}] ${file} (${lineHint})`);\n    lines.push(`  - 문제: ${issue}`);\n    lines.push(`  - 제안: ${suggestion}`);\n  }\n}\n\nlines.push('');\nlines.push('## 결론');\n\nif (findings.length === 0) {\n  lines.push('중요한 문제는 보이지 않습니다. 현재 변경은 이 방향으로 진행해도 됩니다.');\n} else {\n  lines.push(`확인된 이슈 ${findings.length}건을 반영한 뒤 다시 검토하는 것이 안전합니다.`);\n}\n\nreturn {\n  json: {\n    ...$json,\n    comment_markdown: lines.join('\\n')\n  }\n};"
      },
