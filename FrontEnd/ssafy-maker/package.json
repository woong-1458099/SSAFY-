{
  "name": "webprototype-phaser",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "npm@10",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "node node_modules/typescript/bin/tsc --noEmit",
    "validate:scene-registry": "node scripts/validate-scene-registry.mjs",
    "validate:minigame-structure": "node scripts/validate-minigame-structure.mjs",
    "validate:game-assets": "node scripts/validate-game-assets.mjs",
    "build": "npm run typecheck && npm run validate:scene-registry && npm run validate:minigame-structure && npm run validate:game-assets && vite build",
    "preview": "vite preview",
    "validate": "npm run typecheck && npm run validate:scene-registry && npm run validate:minigame-structure && npm run validate:game-assets && npm run validate:authored-story && npm run test:authored-story-validator",
    "validate:authored-story": "node scripts/validate-authored-story.mjs",
    "test:authored-story-validator": "node scripts/test-authored-story-validator.mjs"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "ajv": "^8.18.0",
    "fast-xml-parser": "^5.5.9",
    "typescript": "^5.8.2",
    "vite": "^7.3.1"
  }
}
