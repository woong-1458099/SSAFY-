{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@app/*": ["src/app/*"],
      "@core/*": ["src/core/*"],
      "@shared/*": ["src/shared/*"],
      "@features/*": ["src/features/*"],
      "@scenes/*": ["src/scenes/*"],
      "@infra/*": ["src/infra/*"]
    },
    "lib": ["ES2020", "DOM", "ScriptHost"],
    "types": ["vite/client"]
  },
  "include": ["src"]
}
