        "w2d2_c1_res3": {
          "id": "w2d2_c1_res3",
          "speaker": "SYSTEM",
          "text": "(효련이가 의기양양하게 내 코드를 살펴본다. 나한테는 꽤 친절하네...)"
        },
        "w2d2_c2_res1": {
          "id": "w2d2_c2_res1",
          "speaker": "PLAYER",
          "speakerId": "PLAYER",
          "text": "\"[MM] 내 뒷모습 계속 보고 있었어? 너 나한테 엄청 관심 많구나? ㅋㅋㅋ\"",
          "nextNodeId": "w2d2_c2_res2"
