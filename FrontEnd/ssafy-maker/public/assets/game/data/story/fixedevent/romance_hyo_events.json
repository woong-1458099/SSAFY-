              }
            }
          ]
        },
        "w2d2_c1_res1": {
          "id": "w2d2_c1_res1",
          "speaker": "PLAYER",
          "speakerId": "PLAYER",
          "text": "\"효련아 넌 진짜 천사야 ㅠㅠ 나 진짜 죽을 뻔했어.\"",
          "nextNodeId": "w2d2_c1_res2"
        },
        "w2d2_c1_res2": {
          "id": "w2d2_c1_res2",
          "speaker": "효련",
          "speakerId": "NPC_CLASSMATE_HYORYEON",
          "emotion": "PROUD",
          "text": "\"어휴, 은근 손 많이 가는 타입이라니까. 앉아봐, 어디가 문젠데?\"",
          "nextNodeId": "w2d2_c1_res3"
