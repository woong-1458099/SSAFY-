{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["dialogues"],
  "properties": {
    "dialogues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "startNodeId", "nodes"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "startNodeId": {
            "type": "string",
            "minLength": 1
          },
          "triggerTiming": {
            "type": "object",
            "properties": {
              "week": { "type": "integer" },
              "day": { "type": "integer" },
              "timeOfDay": { "type": "string" }
            }
          },
          "location": {
            "type": "string"
          },
          "eventType": {
            "type": "string"
          },
          "nodes": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "$ref": "#/$defs/dialogueNode"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "dialogueNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "text"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "speaker": {
          "type": "string",
          "minLength": 1
        },
        "speakerId": {
          "type": "string",
          "minLength": 1
        },
        "emotion": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "nextNodeId": {
          "type": "string",
          "minLength": 1
        },
        "choices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dialogueChoice"
          }
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "affectionChanges": {
          "type": "object",
          "propertyNames": {
            "enum": ["minsu", "hyoryeon"]
          },
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },
    "dialogueChoice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "nextNodeId": {
          "type": "string",
          "minLength": 1
        },
        "actionType": {
          "type": "string",
          "enum": ["NORMAL", "LOCKED", "MADNESS", "ROMANCE_EVENT"]
        },
        "statChanges": {
          "type": "object",
          "propertyNames": {
            "enum": ["fe", "be", "teamwork", "luck", "stress", "hp", "money"]
          },
          "additionalProperties": {
            "type": "number"
          }
        },
        "requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dialogueRequirement"
          }
        },
        "affectionRequirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/affectionRequirement"
          }
        },
        "lockedReason": {
          "type": "string"
        },
        "feedbackText": {
          "type": "string"
        },
        "action": {
          "type": "string",
          "minLength": 1
        },
        "setFlags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "affectionChanges": {
          "type": "object",
          "propertyNames": {
            "enum": ["minsu", "hyoryeon"]
          },
          "additionalProperties": {
            "type": "number"
          }
        }
      }
    },
    "dialogueRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stat"],
      "properties": {
        "stat": {
          "type": "string",
          "enum": ["fe", "be", "teamwork", "luck", "stress", "hp", "money", "week", "playerGender"]
        },
        "equals": {
          "type": "string"
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "affectionRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["npcId"],
      "properties": {
        "npcId": {
          "type": "string",
          "enum": ["minsu", "hyoryeon"]
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "label": {
          "type": "string"
        }
      }
    }
  }
}
