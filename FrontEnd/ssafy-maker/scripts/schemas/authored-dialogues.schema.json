{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["dialogues"],
  "properties": {
    "dialogues": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "startNodeId", "nodes"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "startNodeId": {
            "type": "string",
            "minLength": 1
          },
          "nodes": {
            "type": "object",
            "minProperties": 1,
            "additionalProperties": {
              "$ref": "#/$defs/dialogueNode"
            }
          }
        }
      }
    }
  },
  "$defs": {
    "dialogueNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "speaker", "text"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "speaker": {
          "type": "string",
          "minLength": 1
        },
        "speakerId": {
          "type": "string",
          "minLength": 1
        },
        "emotion": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "nextNodeId": {
          "type": "string",
          "minLength": 1
        },
        "choices": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dialogueChoice"
          }
        },
        "action": {
          "type": "string",
          "enum": ["openShop", "openMiniGame", "playDrinking", "playInterview", "playGym", "playRhythm", "playCooking"]
        }
      }
    },
    "dialogueChoice": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "nextNodeId": {
          "type": "string",
          "minLength": 1
        },
        "actionType": {
          "type": "string",
          "enum": ["NORMAL", "LOCKED", "MADNESS"]
        },
        "statChanges": {
          "type": "object",
          "additionalProperties": {
            "type": "number"
          }
        },
        "requirements": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dialogueRequirement"
          }
        },
        "lockedReason": {
          "type": "string"
        },
        "feedbackText": {
          "type": "string"
        },
        "action": {
          "type": "string",
          "enum": ["openShop", "openMiniGame", "playDrinking", "playInterview", "playGym", "playRhythm", "playCooking"]
        }
      }
    },
    "dialogueRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stat"],
      "properties": {
        "stat": {
          "type": "string",
          "enum": ["fe", "be", "teamwork", "luck", "stress", "hp", "gold", "money"]
        },
        "min": {
          "type": "number"
        },
        "max": {
          "type": "number"
        },
        "label": {
          "type": "string"
        }
      }
    }
  }
}
