    {
      "id": "minsu_intro",
      "label": "민수 인트로",
      "startNodeId": "start",
      "nodes": {
        "start": {
          "id": "start",
          "speaker": "민수",
          "text": "모르는 건 바로 묻는 게 빠르다. 혼자 끌어안지 말고."
        }
      }
    },
    {
      "id": "npc_hyewon",
      "label": "혜원 인사",
      "startNodeId": "start",
      "nodes": {
        "start": {
          "id": "start",
          "speaker": "혜원",
          "text": "오늘도 너무 무리하지 말고, 막히는 건 같이 보자.",
          "nextNodeId": "missing_node"
        }
      }
    },
    {
      "id": "npc_myungjin",
      "label": "명진",
      "startNodeId": "intro",
      "nodes": {
        "intro": {
          "id": "intro",
          "speaker": "명진",
          "text": "오늘도 팀 일은 차분하게 정리하면 돼.",
          "choices": [
            {
              "id": "bye",
              "text": "알겠어, 고마워."
            }
          ]
        }
      }
    },
    {
      "id": "npc_yeonwoong",
      "label": "연웅",
      "startNodeId": "intro",
      "nodes": {
        "intro": {
          "id": "intro",
          "speaker": "연웅",
          "text": "문제 하나씩 끝까지 밀어붙이면 늘 실력이 잘 올라요.",
          "choices": [
            {
              "id": "bye",
              "text": "조언 고마워!"
            }
          ]
        }
      }
    },
    {
      "id": "npc_hyoryeon",
      "label": "효련",
      "startNodeId": "intro",
      "nodes": {
        "intro": {
          "id": "intro",
          "speaker": "효련",
          "text": "누적되면 지치니까 티타임이라도 아끼지 마.",
          "choices": [
            {
              "id": "bye",
              "text": "어, 잠깐 쉬어갈게."
            }
          ]
        }
      }
    },
    {
      "id": "npc_jiwoo",
      "label": "지우",
      "startNodeId": "intro",
      "nodes": {
        "intro": {
          "id": "intro",
          "speaker": "지우",
          "text": "팀 프로젝트는 결국 소통이 절반이야. 말을 많이 맞춰보자.",
          "choices": [
            {
              "id": "bye",
              "text": "응, 같이 맞춰보자."
            }
          ]
        }
      }
    },
    {
      "id": "npc_jongmin",
      "label": "종민",
      "startNodeId": "intro",
      "nodes": {
        "intro": {
          "id": "intro",
          "speaker": "종민",
          "text": "체력도 실력이야. 오래 버티려면 페이스 조절이 중요해.",
          "choices": [
            {
              "id": "bye",
              "text": "오늘은 무리하지 않을게."
            }
          ]
        }
      }
    },
    {
      "id": "npc_minsu",
      "label": "민수",
      "startNodeId": "intro",
      "nodes": {
        "intro": {
          "id": "intro",
          "speaker": "민수",
          "text": "모르는 건 바로 묻는 게 빠르다. 혼자 끌어안지 말고.",
          "choices": [
            {
              "id": "bye",
              "text": "그럴게, 고마워."
            }
          ]
        }
      }
    },
    {
      "id": "npc_sunmi",
      "label": "조선미 프로",
      "startNodeId": "intro",
      "nodes": {
        "intro": {
          "id": "intro",
          "speaker": "조선미 프로",
          "text": "기본기를 차근차근 쌓으면 되니 너무 조급해하지 마세요.",
          "choices": [
            {
              "id": "bye",
              "text": "네, 명심할게요."
            }
          ]
        }
      }
    },
    {
      "id": "npc_doyeon",
      "label": "김도연 프로",
      "startNodeId": "intro",
      "nodes": {
        "intro": {
          "id": "intro",
          "speaker": "김도연 프로",
          "text": "흐름을 이해하면 세부 문법은 따라옵니다. 검색하는 습관도 실력이에요.",
          "choices": [
            {
              "id": "bye",
              "text": "알겠습니다!"
            }
          ]
        }
      }
    },
    {
      "id": "npc_hyunseok",
      "label": "이현석 컨설턴트",
      "startNodeId": "intro",
      "nodes": {
        "intro": {
          "id": "intro",
          "speaker": "이현석 컨설턴트",
          "text": "요즘 프로젝트 진행은 어떤가요? 문제가 있으면 빨리 공유하세요.",
          "choices": [
            {
              "id": "bye",
              "text": "네, 확인해볼게요."
            }
          ]
        }
      }
